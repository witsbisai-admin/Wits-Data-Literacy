# ═══════════════════════════════════════════════════════════════
#  Wits Data Literacy Platform — Environment Configuration
#  Copy this file: cp .env.example .env
#  Edit .env with your values — never commit .env to git
# ═══════════════════════════════════════════════════════════════

# ── Deployment ────────────────────────────────────────────────
DOMAIN=your-domain.wits.ac.za    # e.g. datalit.wits.ac.za
HTTP_PORT=80
HTTPS_PORT=443

# ── SSL ───────────────────────────────────────────────────────
SSL_EMAIL=admin@wits.ac.za        # Email for Let's Encrypt cert notifications

# ── Environment ───────────────────────────────────────────────
NODE_ENV=production
